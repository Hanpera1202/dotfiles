# =========================
# tmux 3.2 configuration
# Optimized for Bastion host operations on Linux
# =========================

##### General #####

# Reduce delay after pressing Esc for faster Vim/tmux interaction
set -sg escape-time 1

# Start window numbering from 1 instead of 0
set -g base-index 1

# Start pane numbering from 1 instead of 0
setw -g pane-base-index 1

# Automatically renumber windows after closing one
set -g renumber-windows on

# Reload tmux config quickly
bind r source-file ~/.tmux.conf \; display-message "tmux.conf reloaded"

##### Prefix #####

# Keep default prefix C-b
set -g prefix C-b
unbind C-b
bind C-b send-prefix

##### Splitting Panes #####

# Split horizontally and keep current working directory
bind | split-window -h -c "#{pane_current_path}"

# Split vertically and keep current working directory
bind - split-window -v -c "#{pane_current_path}"

##### Pane Navigation #####

# Move between panes with Vim-like keys
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

##### Pane Resizing #####

# Resize panes with repeatable key bindings
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

##### Pane Management #####

# Show pane numbers for quick selection
bind g display-panes

# Toggle pane zoom
bind z resize-pane -Z

# Toggle synchronized input across panes
bind e setw synchronize-panes \; display-message "synchronize-panes toggled"

##### Window Navigation #####

# Easier window switching
bind -r C-h previous-window
bind -r C-l next-window

##### Mouse #####

# Enable mouse support for pane selection, resizing, and scrolling
set -g mouse on

##### Copy Mode #####

# Use Vim-style key bindings in copy mode
setw -g mode-keys vi

# Enable clipboard integration when terminal supports it
set -s set-clipboard on

# Start selection with v in copy mode
bind-key -T copy-mode-vi v send -X begin-selection

# Copy selection and exit copy mode with y
bind-key -T copy-mode-vi y send -X copy-selection-and-cancel

# Copy selection and exit copy mode with Enter
unbind -T copy-mode-vi Enter
bind-key -T copy-mode-vi Enter send -X copy-selection-and-cancel

# Copy the entire line with Y
bind-key -T copy-mode-vi Y send -X copy-line

##### Terminal / Color #####

# Use a modern terminal definition for tmux
set -g default-terminal "tmux-256color"

# Enable true color support for compatible terminals
set -as terminal-features ",xterm-256color:RGB"
set -as terminal-features ",tmux-256color:RGB"

##### Status Bar #####

# Refresh status bar every 5 seconds
set -g status-interval 5

# Set left and right status lengths
set -g status-left-length 40
set -g status-right-length 100

# Show session name on the left
set -g status-left "#S"

# Show user, host, and current date/time on the right
set -g status-right "#(whoami)@#H | %Y-%m-%d %H:%M"

# Highlight the active window more clearly
setw -g window-status-current-style fg=white,bg=red,bold

##### Quality of Life #####

# Do not rename windows automatically based on running process
set -g allow-rename off

# Increase scrollback history
set -g history-limit 100000

# Show messages for a bit longer
set -g display-time 3000
